{
  "name": "erp-v3-backend",
  "version": "3.0.0",
  "description": "ERP V3.0 - Plataforma empresarial modular con gestión de licencias",
  "main": "dist/main.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern='.unit.test.ts'",
    "test:integration": "jest --testPathPattern='.integration.test.ts'",
    "test:all": "jest --coverage",
    "test:e2e": "cd frontend && npx playwright test && cd ..",
    "test:performance": "artillery run load-tests.yml",
    "test:security": "npm audit && npm run lint",
    "test:report": "bash generate-report.sh",
    "lint": "eslint src --ext .ts",
    "migrate": "node -r ts-node/register src/database/migrate.ts",
    "seed": "node -r ts-node/register src/database/seed.ts"
  },
  "keywords": [
    "erp",
    "express",
    "typescript",
    "postgresql",
    "redis"
  ],
  "author": "Daniel Fernandez",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "firebase-admin": "^13.10.0",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "nodemailer": "^8.0.9",
    "pg": "^8.11.2",
    "redis": "^4.6.10",
    "socket.io": "^4.7.2",
    "stripe": "^13.8.0",
    "uuid": "^14.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.10.6",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "artillery": "^1.7.9",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
