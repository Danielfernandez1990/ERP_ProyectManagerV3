# ERP V3.0 - Configuración Backend
# Backend Node.js + Express + TypeScript

# ============================================================
# PUERTO Y AMBIENTE
# ============================================================
PORT=3000
NODE_ENV=development

# ============================================================
# BASE DE DATOS POSTGRESQL
# ============================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=erp_user
DB_PASSWORD=erp_password_123
DB_NAME=erp_v3_db

# ============================================================
# REDIS CACHE
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_password_123
REDIS_DB=0

# ============================================================
# JWT TOKENS
# ============================================================
JWT_SECRET=your_super_secret_jwt_key_change_in_production_2024!
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production_2024!
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# ============================================================
# EMAIL SMTP (Opcional - para notificaciones)
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="ERP V3.0 <no-reply@erp.local>"

# ============================================================
# STRIPE PAGOS (Opcional - para pagos)
# ============================================================
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_PUBLIC_KEY=pk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# ============================================================
# CORS - PERMITIR FRONTEND
# ============================================================
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ============================================================
# RATE LIMITING
# ============================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=debug

# ============================================================
# AUDITORIA
# ============================================================
AUDIT_ENABLED=true
AUDIT_LOG_PATH=./logs/audit.log

# ============================================================
# NOTAS IMPORTANTES
# ============================================================
# 1. Las credenciales de BD deben coincidir con docker-compose.yml
# 2. JWT_SECRET debe ser una cadena segura en producción
# 3. CORS_ORIGIN debe incluir la URL del frontend
# 4. Cambiar SMTP_USER y SMTP_PASS para enviar emails reales
# 5. Cambiar STRIPE keys para usar pagos reales
